{
  "name": "cross-sell-components",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "storybook": "storybook dev -p 6006 --no-open",
    "build:storybook": "storybook build",
    "build:widgets": "tsx scripts/build-widgets.ts",
    "build:emails": "tsx scripts/build-emails.tsx",
    "build:emails:uat": "tsx scripts/build-emails.tsx --domain-mode=uat",
    "build:emails:production": "tsx scripts/build-emails.tsx --domain-mode=production",
    "send:email:preview": "tsx scripts/send-email-preview.tsx",
    "build": "pnpm build:widgets && pnpm build:emails",
    "serve:examples": "node scripts/serve-static.mjs 4174",
    "format": "node scripts/format-changed.mjs",
    "format:all": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:app:unit": "vitest run src",
    "test:app:widgets": "pnpm build && playwright test tests/playwright/app/widgets",
    "test:app": "pnpm test:app:unit && pnpm test:app:widgets",
    "test:internal:contracts": "vitest run tests/vitest/internal/contracts",
    "test:internal:handoff": "pnpm build && playwright test tests/playwright/internal/handoff",
    "test:internal": "pnpm test:internal:contracts && pnpm test:internal:handoff",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:app && pnpm test:internal"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "resend": "^6.12.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
